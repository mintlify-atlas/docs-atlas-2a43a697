  "keyFeatures": [
    "Execute custom scripts from anywhere with keyboard shortcuts",
    "Support for Shell, AppleScript, Python, Swift, and JavaScript",
    "Metadata-driven configuration for script appearance and behavior",
    "Multiple output modes: silent, compact, fullOutput, and inline",
    "Custom arguments for dynamic script execution",
    "ANSI color support for rich terminal output",
    "Community-driven repository with hundreds of example scripts",
    "Template system for quick script creation"
  ],
  "publicApiSurface": [
    "@raycast.schemaVersion - Schema version metadata",
    "@raycast.title - Script command display name",
    "@raycast.mode - Output mode (silent, compact, fullOutput, inline)",
    "@raycast.packageName - Package display name",
    "@raycast.icon - Icon for the command",
    "@raycast.iconDark - Dark mode icon",
    "@raycast.currentDirectoryPath - Script execution path",
    "@raycast.needsConfirmation - Confirmation dialog flag",
    "@raycast.refreshTime - Auto-refresh interval for inline mode",
    "@raycast.argument1 - First custom argument",
    "@raycast.argument2 - Second custom argument",
    "@raycast.argument3 - Third custom argument",
    "@raycast.author - Script author name",
    "@raycast.authorURL - Author contact URL",
    "@raycast.description - Script description"
  ]
